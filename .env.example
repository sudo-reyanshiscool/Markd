# Cloud accounts and cross-device sync
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Free local Gemma with Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4

# Optional hosted fallback if you ever want one
# GEMINI_API_KEY=your_google_ai_studio_api_key_here
# GEMMA_MODEL=gemma-4-31b-it

# Optional Teams backend
# VITE_API_URL=https://your-teams-backend.example.com

# Firebase (Auth + Firestore)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abc123
